{
  "name": "alexlaz-portfolio",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "dev:landing": "npm run dev --workspace=apps/landing",
    "dev:explore": "npm run dev --workspace=apps/explore",
